{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useExhaustiveDependencies": "error",
        "useHookAtTopLevel": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConfusingVoidType": "error",
        "noEmptyBlockStatements": "error",
        "noAsyncPromiseExecutor": "error",
        "noDoubleEquals": "error"
      },
      "style": {
        "noNonNullAssertion": "error",
        "useConst": "error",
        "noVar": "error",
        "useTemplate": "error",
        "noUselessElse": "error",
        "useShorthandFunctionType": "error",
        "useImportType": "error",
        "useExportType": "error"
      },
      "complexity": {
        "noBannedTypes": "error",
        "noForEach": "warn",
        "noUselessFragments": "error"
      },
      "performance": {
        "noDelete": "warn",
        "noAccumulatingSpread": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "files": {
    "ignore": ["node_modules", "dist", "*.json", "fixtures/**/*.json"]
  }
}
