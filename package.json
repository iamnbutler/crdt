{
  "name": "@iamnbutler/crdt",
  "version": "0.0.1",
  "type": "module",
  "description": "Pure TypeScript CRDT implementation for collaborative text editing",
  "license": "MIT",
  "author": "iamnbutler",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./arena": {
      "types": "./dist/arena/index.d.ts",
      "import": "./dist/arena/index.js"
    },
    "./sum-tree": {
      "types": "./dist/sum-tree/index.d.ts",
      "import": "./dist/sum-tree/index.js"
    },
    "./rope": {
      "types": "./dist/rope/index.d.ts",
      "import": "./dist/rope/index.js"
    },
    "./text": {
      "types": "./dist/text/index.d.ts",
      "import": "./dist/text/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./anchor": {
      "types": "./dist/anchor/index.d.ts",
      "import": "./dist/anchor/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts ./src/arena/index.ts ./src/sum-tree/index.ts ./src/rope/index.ts ./src/text/index.ts ./src/protocol/index.ts ./src/anchor/index.ts --outdir ./dist --target node --splitting",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "bench": "bun run benchmarks/index.ts",
    "bench:ci": "bun run benchmarks/index.ts --ci",
    "bench:text": "bun run benchmarks/text-buffer.ts",
    "bench:text:ci": "bun run benchmarks/text-buffer.ts --ci",
    "bench:sum-tree": "bun run benchmarks/sum-tree.ts",
    "bench:sum-tree:ci": "bun run benchmarks/sum-tree.ts --ci",
    "bench:anchor": "bun run benchmarks/anchor-bench.ts",
    "bench:memory": "bun run benchmarks/memory.ts",
    "bench:memory:ci": "bun run benchmarks/memory.ts --ci",
    "bench:compare": "bun run benchmarks/comparison.ts",
    "bench:compare:ci": "bun run benchmarks/comparison.ts --ci",
    "bench:all": "bun run bench && bun run bench:text && bun run bench:sum-tree && bun run bench:anchor && bun run bench:memory",
    "fixtures:download": "bun run scripts/download-fixtures.ts",
    "bench:record": "bun run scripts/record-benchmarks.ts",
    "bench:record:push": "bun run scripts/record-benchmarks.ts --push",
    "bench:backfill": "bun run scripts/backfill-benchmarks.ts",
    "site:dev": "cd site && bun run dev",
    "site:build": "cd site && bun run build"
  },
  "devDependencies": {
    "@automerge/automerge": "^3.2.4",
    "@biomejs/biome": "1.9.4",
    "@types/bun": "latest",
    "loro-crdt": "^1.10.8",
    "mitata": "1.0.34",
    "typescript": "5.7.2",
    "yjs": "^13.6.30"
  }
}
